# Dependencies
node_modules/

# Lockfiles — Bun is the only package manager (locally and on Vercel).
# The committed bun.lock (text) makes Vercel use Bun >=1.2. Ignore other
# managers' lockfiles so a stray `npm install` can't add a package-lock.json
# that flips Vercel's auto-detection back to npm.
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
.vercel/

# Astro
.astro/

# Environment variables
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.tgz
